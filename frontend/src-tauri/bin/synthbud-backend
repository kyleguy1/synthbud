#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RESOURCE_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
BACKEND_ROOT="${SYNTHBUD_DESKTOP_BACKEND_ROOT:-$RESOURCE_DIR/backend}"

if [ -x "$BACKEND_ROOT/.venv/bin/python" ]; then
  PYTHON_BIN="$BACKEND_ROOT/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="$(command -v python3)"
else
  echo "Unable to find a Python 3 runtime for the synthbud desktop backend." >&2
  exit 1
fi

export SYNTHBUD_DESKTOP_BACKEND_ROOT="$BACKEND_ROOT"
export PYTHONPATH="$BACKEND_ROOT${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m app.desktop_launcher "$@"
