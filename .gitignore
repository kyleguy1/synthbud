# Environment and secrets (never commit real tokens)
.env
backend/.env
*.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.eggs/

# Testing / tooling
.pytest_cache/
.coverage
htmlcov/
node_modules/
frontend/dist/
frontend/.vite/
frontend/src-tauri/target/
frontend/tsconfig.tsbuildinfo

# Desktop build artifacts (generated by scripts/build_desktop_app.sh)
backend/pyinstaller/build/
backend/pyinstaller/dist/
# PyInstaller-frozen backend binary (regenerated by scripts/build_backend_executable.sh)
frontend/src-tauri/bin/synthbud-backend
# Bundled postgres binaries (populated by scripts/bundle_postgres_macos.sh)
frontend/src-tauri/postgres/bin/*
frontend/src-tauri/postgres/lib/*
frontend/src-tauri/postgres/share/*
!frontend/src-tauri/postgres/**/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
